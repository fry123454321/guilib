{
    "version": 8,
    "configurePresets": [
        {
            "name": "Release",
            "displayName": "Release build",
            "description": "Release build",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_release",
            "toolchainFile": "${sourceDir}/build_release/.conan/conan_toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "Debug",
            "displayName": "Debug build",
            "description": "Debug build",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_debug",
            "toolchainFile": "${sourceDir}/build_debug/.conan/conan_toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Release",
            "configurePreset": "Release"
        },
        {
            "name": "Debug",
            "configurePreset": "Debug"
        }
    ]
}
